{
  "name": "chords-viewer",
  "version": "5.0.0",
  "description": "Offline chords app",
  "author": "Stanislav Popov <popstas@gmail.com>",
  "homepage": "https://github.com/popstas/chords-viewer",
  "private": true,
  "scripts": {
    "dev": "nuxt dev --host 0.0.0.0 --port 3001",
    "parse-dev": "bash scripts/parse-dev.sh",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "build-beats": "node scripts/build-beats.js",
    "update-data": "curl https://raw.githubusercontent.com/popstas/chords-data/master/chords.json > chords.json",
    "version": "npm run changelog && git add CHANGELOG.md",
    "postversion": "git push && npm run release",
    "changelog": "npx conventional-changelog-cli -p angular -i CHANGELOG.md -s -r 0",
    "release": "npx conventional-github-releaser -p angular && npm run deploy",
    "deploy": "bash scripts/deploy.sh",
    "lint": "eslint --ext .js,.ts,.vue --ignore-path .gitignore .",
    "test:e2e": "playwright test",
    "precommit": "npm run lint",
    "parse": "bash scripts/parse.sh",
    "parse-and-deploy": "bash scripts/parse-and-deploy.sh"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.0.6",
    "@vueuse/core": "^11.3.0",
    "copy-to-clipboard": "^3.3.3",
    "dateformat": "^3.0.3",
    "element-plus": "^2.5.5",
    "firebase": "^12.0.0",
    "firebaseui": "^6.0.2",
    "fuse.js": "^6.4.0",
    "lodash": "^4.17.21",
    "nosleep.js": "^0.12.0",
    "pinia": "^3.0.2",
    "pinia-plugin-persistedstate": "^4.3.0",
    "qrcode.vue": "^3.6.0",
    "vue": "^3.5.14",
    "vue-qrcode-reader": "^4.0.0",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "webaudiofont": "^2.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@vite-pwa/nuxt": "^0.10.6",
    "eslint": "^8.56.0",
    "nuxt": "3.13.2",
    "sass": "^1.69.0"
  }
}
